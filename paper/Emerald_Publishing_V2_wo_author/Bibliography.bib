	title = {{{SigNet}}: {{A}} Novel Deep Learning Framework for Radio Signal Classification},
	shorttitle = {{{SigNet}}},
	author = {Chen, Zhuangzhi and Cui, Hui and Xiang, Jingyang and Qiu, Kunfeng and Huang, Liang and Zheng, Shilian and Chen, Shichuan and Xuan, Qi and Yang, Xiaoniu},
	year = 2022,
