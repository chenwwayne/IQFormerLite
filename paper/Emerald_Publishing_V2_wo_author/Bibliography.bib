@misc{drokin2024Kolmogorovarnoldconvolutions,
	title = {Kolmogorov-Arnold Convolutions: {{Design}} Principles and Empirical Studies},
	shorttitle = {Kolmogorov-{{Arnold Convolutions}}},
	author = {Drokin, Ivan},
	year = 2024,
